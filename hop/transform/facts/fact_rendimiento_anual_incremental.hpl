  <transform>
    <name>fact_calificaciones input</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>postgres-dwh</connection>
    <execute_each_row>N</execute_each_row>
    <limit>0</limit>
    <sql>SELECT
  id_estudiante
, id_centro
, id_curso
, id_asignatura
, id_tiempo
, id_demografia_familiar
, id_adaptacion
, nota
, desfase_edad
, renta_unidades_consumo
FROM dwh.fact_calificaciones
WHERE id_tiempo IN (
    SELECT id_tiempo FROM dwh.dim_tiempo 
    WHERE curso_academico = '${CURSO_ACTUAL}' OR '${CURSO_ACTUAL}' = ''
)</sql>
    <variables_active>Y</variables_active>
    <attributes/>
    <GUI>
      <xloc>112</xloc>
      <yloc>48</yloc>
    </GUI>
  </transform>
  <transform>
    <name>fact_rendimiento_anual join</name>
    <type>DBJoin</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <cache>N</cache>
    <cache_size>0</cache_size>
    <connection>postgres-dwh</connection>
    <outer_join>Y</outer_join>
    <parameter>
      <field>
        <name>id_estudiante</name>
        <type>Integer</type>
      </field>
      <field>
        <name>curso_academico</name>
        <type>String</type>
      </field>
    </parameter>
    <replace_vars>N</replace_vars>
    <rowlimit>0</rowlimit>
    <sql>SELECT 
  riesgo_academico as hist_riesgo_academico,
  id_curso as curso_anterior
FROM dwh.fact_rendimiento_anual f
JOIN dwh.dim_tiempo t ON f.id_tiempo = t.id_tiempo
WHERE f.id_estudiante = ? 
  AND t.curso_academico &lt; ? 
ORDER BY t.curso_academico DESC, t.orden_evaluacion DESC
LIMIT 1</sql>
    <attributes/>
    <GUI>
      <xloc>112</xloc>
      <yloc>528</yloc>
    </GUI>
  </transform>
  <transform>
    <name>flags analiticos</name>
    <type>Formula</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <formulas>
      <formula>
        <field_name>is_prim_1_2</field_name>
        <formula>IF(AND([cod_ciclo]="PRI", [num_curso]&lt;=2), TRUE(), FALSE())</formula>
        <set_na>N</set_na>
        <value_length>-1</value_length>
        <value_precision>-1</value_precision>
        <value_type>4</value_type>
      </formula>
      <formula>
        <field_name>flag_aprobada</field_name>
        <formula>IF([nota] >= 5, 1, 0)</formula>
        <set_na>N</set_na>
        <value_length>-1</value_length>
        <value_precision>-1</value_precision>
        <value_type>5</value_type>
      </formula>
      <formula>
        <field_name>flag_suspensa</field_name>
        <formula>IF([nota] &lt; 5, 1, 0)</formula>
        <set_na>N</set_na>
        <value_length>-1</value_length>
        <value_precision>-1</value_precision>
        <value_type>5</value_type>
      </formula>
      <formula>
        <field_name>flag_susp_1_2_pri_final</field_name>
        <formula>IF(AND([nota]&lt;5, [is_prim_1_2], [is_final]), 1, 0)</formula>
        <set_na>N</set_na>
        <value_length>-1</value_length>
        <value_precision>-1</value_precision>
