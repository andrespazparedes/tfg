<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>fact_rendimiento_anual_incremental</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description/>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <pipeline_status>0</pipeline_status>
    <parameters>
      <parameter>
        <name>CURSO_ACTUAL</name>
        <default_value/>
        <description>Filtro de Carga Incremental. Deja en BLANCO para extraer todo el histórico (Full Load) o escribe un año (ej. '2025/2026') para extraer solo ese curso.</description>
      </parameter>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>-</created_user>
    <created_date>2026/06/18 20:45:31.776</created_date>
    <modified_user>-</modified_user>
    <modified_date>2026/06/18 20:45:31.776</modified_date>
  </info>
  <notepads>
  </notepads>
  <order>
    <hop>
      <from>fact_calificaciones input</from>
      <to>dim_tiempo lookup</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>dim_adaptacion lookup</from>
      <to>dim_demografia_familiar</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>dim_demografia_familiar</from>
      <to>flags analiticos</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>dim_tiempo lookup</from>
      <to>dim_curso lookup</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>dim_curso lookup</from>
      <to>dim_adaptacion lookup</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>flags analiticos</from>
      <to>id_estudiante id_tiempo sort</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>id_estudiante id_tiempo sort</from>
      <to>id_estudiante id_tiempo group by</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>historico sort</from>
      <to>historico Group by</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Formula Riesgos</from>
      <to>Calculator</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Calculator</from>
      <to>Select values</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>historico Group by</from>
      <to>fact_rendimiento_anual join</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>fact_rendimiento_anual join</from>
      <to>If Null</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>If Null</from>
      <to>Formula Riesgos</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Select values</from>
      <to>Insert / update</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>id_estudiante id_tiempo group by</from>
      <to>historico sort</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transform>
    <name>Calculator</name>
    <type>Calculator</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <calculation>
      <calc_type>ADD</calc_type>
      <field_a>hist_riesgo_academico</field_a>
      <field_b>riesgo_academico_nuevo</field_b>
      <field_name>riesgo_academico</field_name>
      <remove>N</remove>
      <value_length>-1</value_length>
      <value_precision>-1</value_precision>
      <value_type>Integer</value_type>
    </calculation>
    <calculation>
      <calc_type>ADD3</calc_type>
      <field_a>riesgo_academico</field_a>
      <field_b>riesgo_adaptacion</field_b>
      <field_c>pts_riesgo_socioeconomico</field_c>
      <field_name>riesgo_abandono</field_name>
      <remove>N</remove>
      <value_length>-1</value_length>
      <value_precision>-1</value_precision>
      <value_type>Integer</value_type>
    </calculation>
    <failIfNoFile>Y</failIfNoFile>
    <attributes/>
    <GUI>
      <xloc>320</xloc>
      <yloc>624</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Formula Riesgos</name>
    <type>Formula</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <formulas>
      <formula>
        <field_name>tasa_aprobado</field_name>
        <formula>[num_aprobadas] / [num_cursadas] * 100</formula>
        <set_na>N</set_na>
        <value_length>-1</value_length>
        <value_precision>-1</value_precision>
        <value_type>5</value_type>
      </formula>
      <formula>
        <field_name>pts_riesgo_socioeconomico</field_name>
        <formula>IF([riesgo_socioeconomico] > 21, 10, IF([riesgo_socioeconomico] >= 16, 5, 0))</formula>
        <set_na>N</set_na>
        <value_length>-1</value_length>
        <value_precision>-1</value_precision>
        <value_type>5</value_type>
      </formula>
      <formula>
        <field_name>is_repetidor</field_name>
        <formula>IF([id_curso] = [curso_anterior], TRUE(), FALSE())</formula>
        <set_na>N</set_na>
        <value_length>-1</value_length>
        <value_precision>-1</value_precision>
        <value_type>4</value_type>
      </formula>
      <formula>
        <field_name>pts_repetidor</field_name>
        <formula>IF(AND([is_repetidor], [is_prim_1_2]), 40, IF([is_repetidor], 10, 0))</formula>
        <set_na>N</set_na>
        <value_length>-1</value_length>
        <value_precision>-1</value_precision>
        <value_type>5</value_type>
      </formula>
      <formula>
        <field_name>riesgo_academico_nuevo</field_name>
        <formula>([num_suspensas_1_2_pri_final] * 20) + ([num_suspensas_1_2_pri_parc] * 10) + ([num_suspensas_resto_final] * 5) + [num_suspensas_resto_parc] + [pts_repetidor]</formula>
        <set_na>N</set_na>
        <value_length>-1</value_length>
        <value_precision>-1</value_precision>
        <value_type>5</value_type>
      </formula>
    </formulas>
    <attributes/>
    <GUI>
      <xloc>112</xloc>
      <yloc>624</yloc>
    </GUI>
  </transform>
