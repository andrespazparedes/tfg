  <transform>
    <name>riesgo</name>
    <type>Formula</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <formulas>
      <formula>
        <field_name>riesgo_suspensos_evaluacion</field_name>
        <formula>IF([is_primaria_1_2], [num_suspensos_eval] * 10, [num_suspensos_eval] * 1)</formula>
        <replace_field/>
        <set_na>N</set_na>
        <value_length>-1</value_length>
        <value_precision>-1</value_precision>
        <value_type>5</value_type>
      </formula>
      <formula>
        <field_name>riesgo_suspensos_final</field_name>
        <formula>IF([is_primaria_1_2], [num_suspensos_final] * 20, [num_suspensos_final] * 5)</formula>
        <replace_field/>
        <set_na>N</set_na>
        <value_length>-1</value_length>
        <value_precision>-1</value_precision>
        <value_type>5</value_type>
      </formula>
      <formula>
        <field_name>riesgo_repetidor</field_name>
        <formula>IF([is_repetidor], IF([is_primaria_1_2], 40, 10), 0)</formula>
        <replace_field/>
        <set_na>N</set_na>
        <value_length>-1</value_length>
        <value_precision>-1</value_precision>
        <value_type>5</value_type>
      </formula>
    </formulas>
    <attributes/>
    <GUI>
      <xloc>448</xloc>
      <yloc>560</yloc>
    </GUI>
  </transform>
