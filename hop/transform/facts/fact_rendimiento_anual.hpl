  <transform>
    <name>fact_calificaciones input</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>postgres-dwh</connection>
    <execute_each_row>N</execute_each_row>
    <limit>0</limit>
    <sql>SELECT
  id_estudiante
, id_centro
, id_curso
, id_asignatura
, id_tiempo
, id_demografia_familiar
, id_adaptacion
, nota
, desfase_edad
, renta_unidades_consumo
FROM dwh.fact_calificaciones
</sql>
    <variables_active>N</variables_active>
    <attributes/>
    <GUI>
      <xloc>112</xloc>
      <yloc>48</yloc>
    </GUI>
  </transform>
  <transform>
    <name>flags analiticos</name>
    <type>Formula</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <formulas>
      <formula>
        <field_name>is_prim_1_2</field_name>
        <formula>IF(AND([cod_ciclo]="PRI", [num_curso]&lt;=2), TRUE(), FALSE())</formula>
        <set_na>N</set_na>
        <value_length>-1</value_length>
        <value_precision>-1</value_precision>
        <value_type>4</value_type>
      </formula>
      <formula>
        <field_name>flag_aprobada</field_name>
        <formula>IF([nota] >= 5, 1, 0)</formula>
        <set_na>N</set_na>
        <value_length>-1</value_length>
        <value_precision>-1</value_precision>
        <value_type>5</value_type>
      </formula>
      <formula>
        <field_name>flag_suspensa</field_name>
        <formula>IF([nota] &lt; 5, 1, 0)</formula>
        <set_na>N</set_na>
        <value_length>-1</value_length>
        <value_precision>-1</value_precision>
        <value_type>5</value_type>
      </formula>
      <formula>
        <field_name>flag_susp_1_2_pri_final</field_name>
        <formula>IF(AND([nota]&lt;5, [is_prim_1_2], [is_final]), 1, 0)</formula>
        <set_na>N</set_na>
        <value_length>-1</value_length>
        <value_precision>-1</value_precision>
        <value_type>5</value_type>
      </formula>
      <formula>
        <field_name>flag_susp_1_2_pri_parc</field_name>
        <formula>IF(AND([nota]&lt;5, [is_prim_1_2], NOT([is_final])), 1, 0)</formula>
        <set_na>N</set_na>
        <value_length>-1</value_length>
        <value_precision>-1</value_precision>
        <value_type>5</value_type>
      </formula>
      <formula>
        <field_name>flag_susp_resto_final</field_name>
        <formula>IF(AND([nota]&lt;5, NOT([is_prim_1_2]), [is_final]), 1, 0)</formula>
        <set_na>N</set_na>
        <value_length>-1</value_length>
        <value_precision>-1</value_precision>
        <value_type>5</value_type>
      </formula>
      <formula>
        <field_name>flag_susp_resto_parc</field_name>
        <formula>IF(AND([nota]&lt;5, NOT([is_prim_1_2]), NOT([is_final])), 1, 0)</formula>
        <set_na>N</set_na>
        <value_length>-1</value_length>
        <value_precision>-1</value_precision>
        <value_type>5</value_type>
      </formula>
    </formulas>
    <attributes/>
    <GUI>
      <xloc>112</xloc>
      <yloc>240</yloc>
    </GUI>
  </transform>
  <transform>
    <name>historico Group by</name>
    <type>GroupBy</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <add_linenr>N</add_linenr>
    <all_rows>Y</all_rows>
    <directory>${java.io.tmpdir}</directory>
    <fields>
      <field>
        <aggregate>num_suspensas_1_2_pri_final</aggregate>
        <subject>susp_1_2_pri_final</subject>
        <type>CUM_SUM</type>
      </field>
      <field>
        <aggregate>num_suspensas_1_2_pri_parc</aggregate>
        <subject>susp_1_2_pri_parc</subject>
