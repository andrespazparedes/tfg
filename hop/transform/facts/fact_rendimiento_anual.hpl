  <transform>
    <name>suspensos calculator</name>
    <type>Formula</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <formulas>
      <formula>
        <field_name>num_suspensos_eval</field_name>
        <formula>IF(AND([nota] &lt; 5, NOT([is_final])), TRUE(), FALSE())</formula>
        <set_na>N</set_na>
        <value_length>-1</value_length>
        <value_precision>-1</value_precision>
        <value_type>4</value_type>
      </formula>
      <formula>
        <field_name>num_suspensos_final</field_name>
        <formula>IF(AND([nota] &lt; 5, [is_final]), TRUE(), FALSE())</formula>
        <set_na>N</set_na>
        <value_length>-1</value_length>
        <value_precision>-1</value_precision>
        <value_type>4</value_type>
      </formula>
      <formula>
        <field_name>is_primaria_1_2</field_name>
        <formula>IF(AND([cod_ciclo] = "PRI", [num_curso] &lt;= 2), TRUE(), FALSE())</formula>
        <set_na>N</set_na>
        <value_length>-1</value_length>
        <value_precision>-1</value_precision>
        <value_type>4</value_type>
      </formula>
    </formulas>
    <attributes/>
    <GUI>
      <xloc>576</xloc>
      <yloc>224</yloc>
    </GUI>
  </transform>
