      <remove>N</remove>
      <value_length>-1</value_length>
      <value_precision>-1</value_precision>
      <value_type>Integer</value_type>
    </calculation>
    <calculation>
      <calc_type>PERCENT_1</calc_type>
      <conversion_mask/>
      <currency_symbol/>
      <decimal_symbol/>
      <field_a>num_aprobadas</field_a>
      <field_b>num_cursadas</field_b>
      <field_c/>
      <field_name>tasa_aprobado</field_name>
