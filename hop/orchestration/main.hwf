      <name>facts.hwf</name>
      <description/>
      <type>WORKFLOW</type>
      <attributes/>
      <xloc>400</xloc>
      <yloc>128</yloc>
      <parallel>N</parallel>
      <attributes_hac/>
    </action>
    <action>
      <name>Success</name>
      <description/>
      <type>SUCCESS</type>
      <attributes/>
      <xloc>560</xloc>
      <yloc>128</yloc>
      <parallel>N</parallel>
      <attributes_hac/>
    </action>
    <action>
      <loglevel>Error</loglevel>
      <logsubject>Main Workflow</logsubject>
      <logmessage>Uno de los flujos de carga del DWH ha fallado.</logmessage>
      <name>Write to log</name>
      <description/>
      <type>WRITE_TO_LOG</type>
      <attributes/>
      <xloc>400</xloc>
      <yloc>256</yloc>
      <parallel>N</parallel>
      <attributes_hac/>
    </action>
    <action>
      <always_log_rows>N</always_log_rows>
      <name>Abort workflow</name>
      <description/>
      <type>ABORT</type>
      <attributes/>
      <xloc>560</xloc>
      <yloc>256</yloc>
      <parallel>N</parallel>
      <attributes_hac/>
    </action>
    <action>
      <valuetype>variable</valuetype>
      <fieldtype>string</fieldtype>
      <fieldname/>
      <variablename>CURSO_ACTUAL</variablename>
      <mask/>
      <comparevalue/>
      <minvalue/>
      <maxvalue/>
      <successcondition>equal</successcondition>
      <successwhenvarset>Y</successwhenvarset>
      <successbooleancondition>true</successbooleancondition>
      <successnumbercondition>equal</successnumbercondition>
