# ==========================================
# Variables Generales de Infraestructura (Puertos)
# ==========================================
SOURCE_PORT=5432
DWH_PORT=5433
HOP_PORT=8080
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ==========================================
# Configuración de Red Interna de Docker para Hop
# ==========================================
DB_SOURCE_HOST=postgres-source
DB_SOURCE_PORT=5432
DB_DWH_HOST=postgres-dwh
DB_DWH_PORT=5432

# ==========================================
# Credenciales base de datos ORIGEN (Source)
# ==========================================
DB_SOURCE_DB=source
DB_SOURCE_USER=admin
DB_SOURCE_PASS=tfg_password

# ==========================================
# Credenciales base de datos ANALÍTICA (DWH)
# ==========================================
DB_DWH_DB=dwh_db
DB_DWH_USER=admin_dwh
DB_DWH_PASS=tfg_dwh_password

# ==========================================
# FastAPI — Autenticación JWT
# ==========================================
JWT_SECRET_KEY=super-secret-dev-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ==========================================
# FastAPI — Configuración General
# ==========================================
PROJECT_NAME=TFG Dashboard API
API_V1_STR=/api/v1
CORS_ORIGINS=["http://localhost","https://localhost"]

# ==========================================
# Autenticación Administrador Inicial
# ==========================================
DEFAULT_ADMIN_EMAIL=admin@tfg.com
DEFAULT_ADMIN_PASSWORD=admin123
